    { "time": 87.0, "text": "אל מה שכבר ידעתי." },
    { "time": 100.0, "text": "גם אם הדרך ארוכה," },
    { "time": 110.0, "text": "יש נשימה שמחזיקה." },
    { "time": 120.0, "text": "ובסוף הלילה אומר:" },
    { "time": 125.0, "text": "הכול עוד חי בתוכי." }
