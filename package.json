{
  "name": "dkey-music-layer",
  "version": "0.1.0-foundation",
  "private": true,
  "type": "module",
  "description": "Production foundation for DKey Music Layer: DAW + mobile controller + AI intent music runtime.",
  "scripts": {
    "doctor": "node tools/devctl/src/index.mjs doctor",
    "devctl": "node tools/devctl/src/index.mjs status",
    "test": "node tests/smoke/core-pipeline.test.mjs",
    "smoke": "node tools/render-smoke/src/index.mjs",
    "pack:check": "node tools/pack-validator/src/index.mjs assets/demo-packs/hasidic-modern/pack.dml.json",
    "format:check": "npm run pack:check && npm run project:check && npm run arrangement:check && npm run performance:check && npm run midi:check && npm run render:check && npm run export:check && npm run playback:check && npm run preview:check && npm run rights:check && npm run first-song:check && npm run audio:check && npm run smoke",
    "ops:status": "node tools/devctl/src/index.mjs status",
    "ops:pick": "node tools/devctl/src/index.mjs pick",
    "ops:close": "node tools/devctl/src/index.mjs close",
    "ops:run": "node tools/ops-runner/src/index.mjs",
    "ops:verify": "node tools/ops-runner/src/index.mjs verify",
    "ops:full-report": "node tools/ops-runner/src/index.mjs full-report",
    "verify": "npm run doctor && npm test && npm run pack:check && npm run project:check && npm run arrangement:check && npm run performance:check && npm run midi:check && npm run render:check && npm run export:check && npm run playback:check && npm run preview:check && npm run rights:check && npm run first-song:check && npm run audio:check && npm run smoke && npm run ops:status",
    "project:check": "node tools/project-validator/src/index.mjs assets/demo-projects/hasidic-modern/project.dml.json",
    "arrangement:check": "node tools/arrangement-validator/src/index.mjs assets/demo-arrangements/hasidic-modern/arrangement.dml.json",
    "performance:check": "node tools/performance-validator/src/index.mjs assets/demo-performances/hasidic-modern/performance.dml.json",
    "midi:check": "node tools/midi-event-validator/src/index.mjs assets/demo-midi-events/hasidic-modern/midi-events.dml.json",
    "debug-midi:render": "node tools/debug-midi-renderer/src/index.mjs assets/demo-midi-events/hasidic-modern/midi-events.dml.json generated/debug-midi/hasidic-modern/debug-midi-render.dml.json",
    "debug-midi:check": "node tools/debug-midi-renderer/src/check.mjs generated/debug-midi/hasidic-modern/debug-midi-render.dml.json",
    "render:check": "npm run debug-midi:render && npm run debug-midi:check",
    "midi-file:write": "node tools/standard-midi-writer/src/index.mjs assets/demo-midi-events/hasidic-modern/midi-events.dml.json generated/standard-midi/hasidic-modern/demo-hasidic-modern.mid",
    "midi-file:check": "node tools/standard-midi-writer/src/check.mjs generated/standard-midi/hasidic-modern/demo-hasidic-modern.mid",
    "export:check": "npm run midi-file:write && npm run midi-file:check",
    "sample-trigger:check": "node tools/sample-trigger-validator/src/index.mjs assets/demo-sample-trigger-maps/hasidic-modern/sample-trigger-map.dml.json",
    "playback-plan:write": "node tools/playback-planner/src/index.mjs assets/demo-midi-events/hasidic-modern/midi-events.dml.json assets/demo-sample-trigger-maps/hasidic-modern/sample-trigger-map.dml.json generated/playback-plans/hasidic-modern/playback-plan.dml.json",
    "playback-plan:check": "node tools/playback-planner/src/check.mjs generated/playback-plans/hasidic-modern/playback-plan.dml.json",
    "playback:check": "npm run sample-trigger:check && npm run playback-plan:write && npm run playback-plan:check",
    "sample-slot-preview:write": "node tools/sample-slot-preview-renderer/src/index.mjs generated/playback-plans/hasidic-modern/playback-plan.dml.json generated/sample-slot-previews/hasidic-modern/sample-slot-preview.dml.json",
    "sample-slot-preview:check": "node tools/sample-slot-preview-renderer/src/check.mjs generated/sample-slot-previews/hasidic-modern/sample-slot-preview.dml.json",
    "preview:check": "npm run sample-slot-preview:write && npm run sample-slot-preview:check",
    "asset-rights:write": "node tools/asset-rights-validator/src/index.mjs generated/playback-plans/hasidic-modern/playback-plan.dml.json assets/rights/hasidic-modern/asset-rights.dml.json",
    "asset-rights:check": "node tools/asset-rights-validator/src/check.mjs assets/rights/hasidic-modern/asset-rights.dml.json generated/playback-plans/hasidic-modern/playback-plan.dml.json",
    "rights:check": "npm run asset-rights:write && npm run asset-rights:check",
    "first-song:check": "node tools/first-song-validator/src/index.mjs assets/demo-first-songs/hasidic-modern/first-song.dml.json",
    "audio:write": "node tools/audio-wav-renderer/src/index.mjs assets/demo-midi-events/hasidic-modern/midi-events.dml.json generated/audio/hasidic-modern/first-song.wav",
    "audio:file-check": "node tools/audio-wav-renderer/src/check.mjs generated/audio/hasidic-modern/first-song.wav",
    "audio:check": "npm run audio:write && npm run audio:file-check"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "keywords": [
    "daw",
    "ai-music",
    "intent-engine",
    "sample-engine",
    "stems",
    "arranger"
  ],
  "license": "UNLICENSED"
}
